// ─────────────────────────────────────────────────────────────────────────────
// SQYSH — Prisma schema
//
// workflow:
//   npx prisma db push
//   npx prisma generate
//
// conventions:
//   - models PascalCase, tables/columns snake_case via @@map/@map
//   - cuid ids everywhere
//   - createdAt/updatedAt on anything a human creates
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // pooled (pgbouncer) — runtime
  directUrl = env("DIRECT_URL") // direct — migrations
}

// ── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  SUPER_USER
  ADMIN
  CLIENT
}

enum InquiryStatus {
  NEW
  CONTACTED
  IN_DISCUSSION
  WON
  CLOSED
  SCAM
}

// ── Models ────────────────────────────────────────────────────────────────────

model Inquiry {
  id        String        @id @default(cuid())
  name      String        @db.VarChar(120)
  company   String?       @map("company_name") @db.VarChar(160)
  email     String        @db.VarChar(254)
  phone     String?       @db.VarChar(30)
  message   String
  status    InquiryStatus @default(NEW)
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")

  @@index([status, createdAt(sort: Desc)])
  @@map("inquiries")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique @db.VarChar(254)
  // NextAuth-required fields:
  name          String?   @db.VarChar(160)
  image         String?   @db.Text
  emailVerified DateTime? @map("email_verified")
  // your existing fields — made nullable so OAuth sign-in doesn't violate NOT NULL:
  firstName     String?   @map("first_name") @db.VarChar(80)
  lastName      String?   @map("last_name") @db.VarChar(80)
  phone         String?   @db.VarChar(30)
  company       String?   @db.VarChar(50)
  role          Role      @default(CLIENT)
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  accounts Account[]
  sessions Session[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model TrafficSource {
  id     String @id @default(cuid())
  source String @unique @db.VarChar(60) // the utm_source value: "pride-banner", "core"
  count  Int    @default(0)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("traffic_sources")
}

model Project {
  id          String  @id @default(cuid())
  title       String
  location    String?
  description String?

  photos ProjectPhoto[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("projects")
}

model ProjectPhoto {
  id String @id @default(cuid())

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  url String
  alt String?

  // controls display order
  order    Int     @default(0)
  featured Boolean @default(false)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("project_photos")
}

model Testimonial {
  id String @id @default(cuid())

  name    String
  title   String? // "Owner", "CEO", "Marketing Director"
  company String?

  quote     String
  avatarUrl String? // optional photo/logo

  order     Int     @default(0)
  isVisible Boolean @default(true)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("testimonials")
}
